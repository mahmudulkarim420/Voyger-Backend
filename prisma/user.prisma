model User {
  id                        String    @id @default(uuid())
  name                      String
  email                     String    @unique
  emailVerified             Boolean   @default(false)
  image                     String?
  role                      Role      @default(USER)
  requiresDeviceManagement  Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  accounts                  Account[]
  sessions                  Session[]
}