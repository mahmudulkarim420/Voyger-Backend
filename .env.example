# =============================================================================
# Voyger Backend — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values for your environment.
#
#   cp .env.example .env
#
# SECURITY: Never commit the real `.env` file. It is git-ignored by default.
# This file contains ONLY keys and placeholder descriptions — no secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Application environment. One of: development | production | test | provision
NODE_ENV=development

# Port the HTTP server listens on.
PORT=5001

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=SCHEMA
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Secret used to sign session cookies. Generate a strong random string:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the backend (scheme + host + port only — NO path).
BETTER_AUTH_URL=http://localhost:5000

# Comma-separated list of origins allowed by Better Auth's CSRF check.
# Include every frontend origin that calls the API.
TRUSTED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Social Login — Google
# -----------------------------------------------------------------------------
# Obtain credentials at: https://console.cloud.google.com/apis/credentials
# Both values must be set together (or both left empty to disable Google login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Social Login — Facebook
# -----------------------------------------------------------------------------
# Obtain credentials at: https://developers.facebook.com/apps/
# Both values must be set together (or both left empty to disable Facebook login).
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
